{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "max_open_trades": 2,
  "stake_currency": "USDT",
  "stake_amount": 75,
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": true,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "liquidation_buffer": 0.05,
  "futures_funding_rate": 0.0,
  "timeframe": "5m",
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": ["BTC/USDT:USDT", "ETH/USDT:USDT"],
    "pair_blacklist": []
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "freqai": {
    "enabled": true,
    "identifier": "autoresearch-v1",
    "purge_old_models": 2,
    "train_period_days": 30,
    "backtest_period_days": 7,
    "live_retrain_hours": 6,
    "expiration_hours": 12,
    "conv_width": 64,
    "feature_parameters": {
      "include_timeframes": [
        "5m",
        "15m",
        "1h"
      ],
      "include_corr_pairlist": ["BTC/USDT:USDT", "ETH/USDT:USDT"],
      "label_period_candles": 24,
      "include_shifted_candles": 2,
      "indicator_periods_candles": [
        14,
        28,
        56
      ],
      "principal_component_analysis": false,
      "plot_feature_importances": 0
    },
    "data_split_parameters": {
      "test_size": 0.25,
      "shuffle": false,
      "random_state": 42
    },
    "model_training_parameters": {
      "learning_rate": 0.0003,
      "trainer_kwargs": {
        "batch_size": 64,
        "n_steps": 5000,
        "n_epochs": null
      },
      "model_kwargs": {
        "hidden_dim": 512,
        "n_layer": 3,
        "dropout_percent": 0.25,
        "fc_hidden_dim": 256
      }
    }
  },
  "internals": {
    "process_throttle_secs": 5
  }
}
